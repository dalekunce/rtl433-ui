# Copy this file to .env and edit as needed.
# All values below are the defaults — only change what you need.

# Web server port
PORT=3000

# MQTT broker URL
MQTT_URL=mqtt://localhost:1883

# Full path to the rtl_433 binary (default assumes it's on PATH via Homebrew)
RTL433_BIN=rtl_433

# Extra arguments passed to rtl_433 (space-separated).
# -F json   → JSON output (required)
# -M utc    → UTC timestamps
# -M level  → include RSSI/SNR in output
# Add -d 0  to select a specific dongle by index if you have multiple.
RTL433_ARGS=-F json -M utc -M level

# Seconds before an unseen device is removed from the live list.
# Set to 0 to keep devices forever until the server restarts.
FORGET_AFTER_SECONDS=0
