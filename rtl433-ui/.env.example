# Copy this file to .env and edit as needed.
# All values below are the defaults — only change what you need.

# Web server port
PORT=3000

# MQTT broker URL
MQTT_URL=mqtt://localhost:1883

# MQTT credentials (optional — leave blank if your broker has no auth)
MQTT_USERNAME=
MQTT_PASSWORD=

# rtl_433 binary name or path (default assumes it's on PATH)
RTL433_BIN=rtl_433

# Path to the rtl_433 config file (optional — place an rtl_433.conf here).
# Without a config file the add-on hops 433.92M / 868M / 315M / 915M automatically.
# RTL433_CONFIG=/data/rtl433.conf

# Seconds before an unseen device is removed from the live list.
# Set to 0 to keep devices forever until the server restarts.
FORGET_AFTER_SECONDS=0

# Path to the browser-saved settings file (MQTT URL overrides set via the UI).
# Leave unset to use config/settings.json (default for local dev).
# The HA add-on sets this to /data/settings.json automatically.
# SETTINGS_FILE=config/settings.json

